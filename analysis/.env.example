# Phase 2 analysis environment (researchers only). Keep secrets out of git.

# Where to read collected responses from (dev: the app's local store).
SOURCE_JSON=../.data/store.json

# If reading directly from Supabase instead:
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Generation backend: "local" (default, strictest) or "api" (approval required).
GEN_BACKEND=local

# ONLY set if an approved API model is permitted by ethics/data-protection.
OPENAI_API_KEY=
